# Copy to .env and fill in. Never commit .env.

# Google OAuth client ID for the dashboard — "Web application" type, created in
# the SAME Google Cloud project as the extension so it reads the same Drive
# appDataFolder file. Public client (no secret). Authorized JS origin must
# include your dev origin (http://localhost:5173) and later your prod origin.
VITE_GOOGLE_CLIENT_ID=
